---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getExhibit, exhibitSlugs } from '../../lib/exhibits';
import SqliteFileFormat from '../../components/diagrams/SqliteFileFormat.astro';
import MvccTimeline from '../../components/diagrams/MvccTimeline.astro';
import Replication from '../../components/diagrams/Replication.astro';
import VectorIndex from '../../components/diagrams/VectorIndex.astro';
import { withBase } from '../../consts';

export function getStaticPaths() {
  return exhibitSlugs().map((slug) => ({ params: { slug } }));
}

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect(withBase('/gallery/'));
}
const entry = getExhibit(slug);
if (!entry) {
  return new Response(`Unknown exhibit "${slug}"`, { status: 404 });
}

const DIAGRAM_MAP: Record<string, any> = {
  SqliteFileFormat,
  MvccTimeline,
  Replication,
  VectorIndex,
};
---

<BaseLayout title={entry.name} description={entry.tagline}>
  <article>
    <a
      href={withBase('/gallery/')}
      class="font-mono text-xs text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]"
    >
      ← back to gallery
    </a>
    <header class="mt-3 mb-10">
      <div class="mb-4 flex flex-wrap items-center gap-2">
        <span class="pill">{entry.paradigm}</span>
        <span
          class="pill"
          style="background:transparent;border-color:var(--color-border);color:var(--color-fg-muted)"
        >
          {entry.language}
        </span>
        <span
          class="pill"
          style="background:transparent;border-color:var(--color-border);color:var(--color-fg-muted)"
        >
          est. {entry.initialRelease}
        </span>
        <span
          class="pill"
          style="background:transparent;border-color:var(--color-border);color:var(--color-fg-muted)"
        >
          {entry.license}
        </span>
      </div>
      <h1 class="display-heading mb-3 text-5xl" style={`color:${entry.accent}`}>{entry.name}</h1>
      <p class="max-w-3xl text-xl text-[var(--color-fg-muted)]">{entry.tagline}</p>
    </header>

    <section class="mb-12">
      <p class="max-w-3xl text-lg leading-relaxed">{entry.summary}</p>
    </section>

    <section class="mb-12 grid gap-3 sm:grid-cols-2 md:grid-cols-4">
      {
        entry.highlights.map((h) => (
          <div class="panel p-4">
            <div class="font-mono text-xs tracking-wider text-[var(--color-fg-muted)] uppercase">
              {h.label}
            </div>
            <div class="display-heading mt-1 text-lg" style={`color:${entry.accent}`}>
              {h.value}
            </div>
          </div>
        ))
      }
    </section>

    <section class="mb-12 grid gap-4 md:grid-cols-2">
      {
        entry.features.map((f) => (
          <div class="panel p-5">
            <h3 class="display-heading mb-2 text-base" style={`color:${entry.accent}`}>
              {f.title}
            </h3>
            <p class="text-sm text-[var(--color-fg-muted)]">{f.detail}</p>
          </div>
        ))
      }
    </section>

    {
      entry.sections.map((s) => (
        <section class="mb-12 max-w-3xl">
          <h2 class="display-heading mb-4 text-2xl">
            <span class="accent-rule mr-3 inline-block align-middle" />
            {s.heading}
          </h2>
          {s.paragraphs.map((p) => (
            <p class="mb-3 leading-relaxed text-[var(--color-fg)]">{p}</p>
          ))}
          {s.bullets && (
            <ul class="mb-3 list-disc space-y-1 pl-6 text-[var(--color-fg-muted)]">
              {s.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          )}
          {s.code && (
            <pre class="code-block">
              <code data-lang={s.codeLanguage ?? ''}>{s.code}</code>
            </pre>
          )}
        </section>
      ))
    }

    <section class="mb-12">
      <h2 class="display-heading mb-4 text-2xl">
        <span class="accent-rule mr-3 inline-block align-middle"></span>
        Diagrams
      </h2>
      {
        entry.diagrams.map((d) => {
          const Comp = DIAGRAM_MAP[d.component];
          if (!Comp) {
            return (
              <div class="panel p-4 text-sm text-[var(--color-fg-muted)]">
                Diagram <code>{d.component}</code> not implemented yet. {d.description}
              </div>
            );
          }
          return <Comp />;
        })
      }
    </section>
  </article>
</BaseLayout>
