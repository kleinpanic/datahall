---
import { NAV, SITE_TITLE, withBase } from '../consts';

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header
  class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg-elevated)]/80 backdrop-blur"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href={withBase('/')} class="display-heading text-lg tracking-tight">
      <span class="accent-text">▣</span>
      <span class="ml-2">{SITE_TITLE}</span>
    </a>
    <nav class="flex items-center gap-1 text-sm">
      {
        NAV.map((item) => {
          const isActive =
            pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href));
          return (
            <a
              href={withBase(item.href)}
              class:list={[
                'rounded-md px-3 py-1.5 transition-colors',
                isActive
                  ? 'bg-[rgba(0,255,225,0.08)] text-[var(--color-accent)]'
                  : 'text-[var(--color-fg-muted)] hover:text-[var(--color-fg)]',
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
