---
/**
 * Vector index diagram — HNSW-style layered graph used by Qdrant and LanceDB.
 * Six points in 2D; an arrow shows a top-layer neighbor traversal.
 */
---

<figure class="panel my-6 p-4">
  <figcaption class="mb-3 font-mono text-xs tracking-widest text-[var(--color-fg-muted)] uppercase">
    Vector index · HNSW layered graph
  </figcaption>
  <svg
    viewBox="0 0 720 320"
    role="img"
    aria-label="HNSW layered graph: six vectors arranged across three layers, with an arrow tracing a top-down neighbor traversal"
    class="h-auto w-full"
  >
    <!-- layer labels -->
    <text x="20" y="60" fill="#8b95a7" font-size="10" font-family="ui-monospace">L2 (top)</text>
    <text x="20" y="160" fill="#8b95a7" font-size="10" font-family="ui-monospace">L1</text>
    <text x="20" y="270" fill="#8b95a7" font-size="10" font-family="ui-monospace">L0 (base)</text>

    <!-- L2 nodes (sparse) -->
    <g>
      <circle cx="180" cy="60" r="8" fill="#00ffe1"></circle>
      <circle cx="500" cy="60" r="8" fill="#00ffe1"></circle>
      <line x1="188" y1="60" x2="492" y2="60" stroke="#00ffe155"></line>
    </g>

    <!-- L1 nodes -->
    <g>
      <circle cx="120" cy="160" r="8" fill="#7c5cff"></circle>
      <circle cx="320" cy="160" r="8" fill="#7c5cff"></circle>
      <circle cx="540" cy="160" r="8" fill="#7c5cff"></circle>
      <line x1="128" y1="160" x2="312" y2="160" stroke="#7c5cff55"></line>
      <line x1="328" y1="160" x2="532" y2="160" stroke="#7c5cff55"></line>
      <!-- dashed L1 connections to L2 -->
      <line x1="320" y1="152" x2="180" y2="68" stroke="#7c5cff33" stroke-dasharray="3 3"></line>
      <line x1="540" y1="152" x2="500" y2="68" stroke="#7c5cff33" stroke-dasharray="3 3"></line>
    </g>

    <!-- L0 base layer (densest) -->
    <g>
      <circle cx="80" cy="270" r="6" fill="#ff5d8f"></circle>
      <circle cx="200" cy="290" r="6" fill="#ff5d8f"></circle>
      <circle cx="360" cy="270" r="6" fill="#ff5d8f"></circle>
      <circle cx="480" cy="290" r="6" fill="#ff5d8f"></circle>
      <circle cx="600" cy="270" r="6" fill="#ff5d8f"></circle>
      <circle cx="280" cy="240" r="6" fill="#ff5d8f"></circle>
      <line x1="80" y1="270" x2="200" y2="290" stroke="#ff5d8f55"></line>
      <line x1="200" y1="290" x2="360" y2="270" stroke="#ff5d8f55"></line>
      <line x1="360" y1="270" x2="480" y2="290" stroke="#ff5d8f55"></line>
      <line x1="480" y1="290" x2="600" y2="270" stroke="#ff5d8f55"></line>
      <line x1="280" y1="240" x2="360" y2="270" stroke="#ff5d8f55"></line>
      <line x1="200" y1="290" x2="280" y2="240" stroke="#ff5d8f55"></line>
      <!-- dashed L0 connections to L1 -->
      <line x1="200" y1="282" x2="120" y2="168" stroke="#ff5d8f33" stroke-dasharray="3 3"></line>
      <line x1="360" y1="262" x2="320" y2="168" stroke="#ff5d8f33" stroke-dasharray="3 3"></line>
      <line x1="600" y1="262" x2="540" y2="168" stroke="#ff5d8f33" stroke-dasharray="3 3"></line>
    </g>

    <!-- query traversal -->
    <g>
      <path
        d="M650,40 L180,60 L320,160 L360,270"
        fill="none"
        stroke="#f5a623"
        stroke-width="2"
        stroke-linecap="round"
        stroke-dasharray="8 4"
        class="dh-dash"></path>
      <text x="650" y="32" fill="#f5a623" font-size="11" font-family="ui-monospace">query q</text>
    </g>
  </svg>
</figure>
