---
/**
 * SQLite single-file page layout.
 *
 * Visually depicts the on-disk layout: a 100-byte header, then 1-N pages
 * (B-tree leaf or interior, freelist, overflow, payload overflow). Animates
 * the page-walk so it feels like a live read.
 */
---

<figure class="panel my-6 p-4">
  <figcaption class="mb-3 font-mono text-xs tracking-widest text-[var(--color-fg-muted)] uppercase">
    SQLite · On-disk file layout
  </figcaption>
  <svg
    viewBox="0 0 720 280"
    role="img"
    aria-label="SQLite file: 100-byte header followed by a chain of pages (B-tree interior, leaf, freelist)"
    class="h-auto w-full"
  >
    <defs>
      <linearGradient id="dh-page-leaf" x1="0" x2="1">
        <stop offset="0" stop-color="#00ffe1" stop-opacity="0.18"></stop>
        <stop offset="1" stop-color="#00ffe1" stop-opacity="0.05"></stop>
      </linearGradient>
      <linearGradient id="dh-page-int" x1="0" x2="1">
        <stop offset="0" stop-color="#7c5cff" stop-opacity="0.18"></stop>
        <stop offset="1" stop-color="#7c5cff" stop-opacity="0.05"></stop>
      </linearGradient>
    </defs>

    <!-- File header -->
    <g>
      <rect x="20" y="40" width="120" height="200" rx="6" fill="#11161d" stroke="#1f2733"></rect>
      <text
        x="80"
        y="62"
        text-anchor="middle"
        fill="#8b95a7"
        font-size="11"
        font-family="ui-monospace"
      >
        file header
      </text>
      <text
        x="80"
        y="80"
        text-anchor="middle"
        fill="#e5e9f0"
        font-size="14"
        font-family="ui-monospace"
      >
        100 B
      </text>
      <line x1="32" y1="100" x2="128" y2="100" stroke="#1f2733"></line>
      <text
        x="80"
        y="118"
        text-anchor="middle"
        fill="#8b95a7"
        font-size="10"
        font-family="ui-monospace"
      >
        magic
      </text>
      <text
        x="80"
        y="138"
        text-anchor="middle"
        fill="#8b95a7"
        font-size="10"
        font-family="ui-monospace"
      >
        page_size
      </text>
      <text
        x="80"
        y="158"
        text-anchor="middle"
        fill="#8b95a7"
        font-size="10"
        font-family="ui-monospace"
      >
        schema cookie
      </text>
      <text
        x="80"
        y="178"
        text-anchor="middle"
        fill="#8b95a7"
        font-size="10"
        font-family="ui-monospace"
      >
        freelist head
      </text>
      <text
        x="80"
        y="198"
        text-anchor="middle"
        fill="#8b95a7"
        font-size="10"
        font-family="ui-monospace"
      >
        wal / journal
      </text>
    </g>

    <!-- Pages -->
    <g>
      <g transform="translate(180,40)">
        <rect width="100" height="200" rx="6" fill="url(#dh-page-int)" stroke="#7c5cff55"></rect>
        <text
          x="50"
          y="22"
          text-anchor="middle"
          fill="#7c5cff"
          font-size="11"
          font-family="ui-monospace">page 1</text
        >
        <text
          x="50"
          y="40"
          text-anchor="middle"
          fill="#8b95a7"
          font-size="10"
          font-family="ui-monospace">B-tree interior</text
        >
      </g>
      <g transform="translate(300,40)">
        <rect width="100" height="200" rx="6" fill="url(#dh-page-leaf)" stroke="#00ffe155"></rect>
        <text
          x="50"
          y="22"
          text-anchor="middle"
          fill="#00ffe1"
          font-size="11"
          font-family="ui-monospace">page 2</text
        >
        <text
          x="50"
          y="40"
          text-anchor="middle"
          fill="#8b95a7"
          font-size="10"
          font-family="ui-monospace">B-tree leaf</text
        >
      </g>
      <g transform="translate(420,40)">
        <rect width="100" height="200" rx="6" fill="url(#dh-page-leaf)" stroke="#00ffe155"></rect>
        <text
          x="50"
          y="22"
          text-anchor="middle"
          fill="#00ffe1"
          font-size="11"
          font-family="ui-monospace">page 3</text
        >
        <text
          x="50"
          y="40"
          text-anchor="middle"
          fill="#8b95a7"
          font-size="10"
          font-family="ui-monospace">B-tree leaf</text
        >
      </g>
      <g transform="translate(540,40)">
        <rect
          width="100"
          height="200"
          rx="6"
          fill="#11161d"
          stroke="#1f2733"
          stroke-dasharray="4 3"
          class="dh-dash"></rect>
        <text
          x="50"
          y="22"
          text-anchor="middle"
          fill="#8b95a7"
          font-size="11"
          font-family="ui-monospace">…</text
        >
        <text
          x="50"
          y="40"
          text-anchor="middle"
          fill="#8b95a7"
          font-size="10"
          font-family="ui-monospace">more pages</text
        >
      </g>
    </g>

    <!-- WAL stripe -->
    <g>
      <rect x="20" y="252" width="620" height="14" rx="3" fill="#f5a62322" stroke="#f5a62355"
      ></rect>
      <text
        x="330"
        y="262"
        text-anchor="middle"
        fill="#f5a623"
        font-size="10"
        font-family="ui-monospace"
      >
        write-ahead log (separate file, journal or wal mode)
      </text>
    </g>
  </svg>
</figure>
